<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Afinador</title>
</head>
<body>

<div style="text-align:center; padding:30px; background:#1e1e2f; border-radius:12px; color:white; width:100%; height:100%; display:flex; flex-direction:column; justify-content:space-between;">
  
  <h2>🎤 Afinador Pro</h2>

  <button id="startBtn" style="background: linear-gradient(45deg, #00c6ff, #0072ff); border: none; padding: 10px 18px; color: white; font-weight: bold; border-radius: 8px; cursor: pointer;">
    Ativar Microfone
  </button>

  <p>Frequência: <span id="freq">--</span> Hz</p>
  <p>Nota: <span id="note">--</span></p>

  <div style="height:10px; background:#444; border-radius:5px; position:relative;">
    <div style="width:100%; height:10px; background:linear-gradient(90deg, red, yellow, green, yellow, red);"></div>
    <div id="indicator" style="position:absolute; top:-5px; left:50%; width:4px; height:20px; background:white;"></div>
  </div>

  <p id="status">--</p>

</div>

<script>
alert("Arquivo carregado com sucesso");
</script>

</body>
</html>
